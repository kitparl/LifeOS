# ENV=dev → development mode (production=false, insecure cookies OK for localhost)
# ENV=production (default) → production mode (secure cookies, no /docs)
ENV=dev
DATABASE_URL=sqlite+aiosqlite:///./lifeos_dev.db
SECRET_KEY=dev-secret-change-in-production
CORS_ORIGINS=http://localhost:4200
OPENAI_API_KEY=
AI_CHAT_MODEL=gpt-4o-mini
AI_EMBEDDING_MODEL=text-embedding-3-small

# Optional overrides (unset = derived from ENV)
# COOKIE_SECURE=false
